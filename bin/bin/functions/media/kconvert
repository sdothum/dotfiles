# ................................................................ ebook convert

# Usage: [dropcap=<class>] kconvert [<format>|css=<css>]* <epub>*

option=noformat

# SEE: econvert
while : ;do
	case "$1" in
		css=*    ) css="\"$1\""    ;; # BECAUSE: protect spaces within $<var> (css statement)
		default  ) option=default  ;;
		justify  ) option=justify  ;;
		format   ) unset option    ;;
		noformat ) option=noformat ;;
		poetry   ) option=noformat ;; # retain poetry formatting
		all      ) option=all      ;;
		*        ) break           ;;
	esac
	shift
done

books() {
	if [ "$1" ] ;then
		echo $@ | sed -r "s/\.(epub|azw3|mobi) */.\1/g"
	else
		ls -1 *.epub | sed "s/\.epub */.epub/g"
	fi
}

books | while read book ;do
	econvert azw3 $css $option "$book"  # kindle
	econvert epub $css $option "$book"  # koreader
done

