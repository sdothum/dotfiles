# Media
# ══════════════════════════════════════════════════════════════════════════════

# ...................................................................... youtube

# Usage: youtube [-d] <url>

if [ $1 = '-d' ] ;then
	cd /net/media/videos/youtube/
	notify 10 "youtube" "downloading..\n$2"
	yt-dlp "$2"
	notify critical 10 "youtube" "$2\ncompleted"
	exit
fi

# stream youtube to mpv (to remove ads)
# yt-dlp -o - "$1" | mpv --x11-name=youtube -
WID=$(pfw)
notify 10 "youtube" "loading..\n$1"
window hide

# NOTE: long streams can hang requiring closing mpv manually (??) cause unknown
# HACK: stream in background and wait on mpv (to close automatically or manually) to cleanup potential dangling yt-dlp
videomode on
killall -9 -q mpv
yt-dlp -o - "$1" | mpv - &
pidwait -f mpv
killall -9 -q yt-dlp
videomode off

# restore browser page
sirocco window_focus $WID
