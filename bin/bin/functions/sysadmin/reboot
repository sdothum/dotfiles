# ....................................................................... reboot

# Usage: reboot [noprompt]

# NOTE: reboot from console is not initialized with WM environment
REBOPT="$SESSION/$(cat $HOME/.windowmanager)/reboot"
DELAY="$REBOPT/delay"
PREHALT="$REBOPT/pre-halt"

[ -d $DELAY ] && delay=$(ls -1 $DELAY) || delay=5  # reboot delay window

if [ -z $1 ] ;then
	ifno 'reboot kernel' && exit
	ifno "passive (delayed) boot into default window manager" && rm -f $SESSION/boot:wm || echo $WM >$SESSION/boot:wm
fi

# HACK: stop services that cause halt "stop time" exception messages (or appear to STOPPD twice!)
# NOTE: background processes take advantage of reboot count down delay :-)
prehalt() {
	ls -1 $HOME/.config/dinit.d/pre-halt.d 2>/dev/null | sort | while read service ;do
		ditto pre-halt.d "$service"
		(sv stop $service 2>/dev/null || sv stop --force $service) &
	done
	sleep 0.1
}

if console ;then
	echo
	[ -d $PREHALT ] && void 'dinit' && prehalt
	trap "tput cnorm; exit" INT  # restore cursor on break
	printf "\r\33[2K\n"          # clear shell prompt leader SEE: x script
	tput civis                   # hide cursor
	[ $delay -gt 0 ] && for i in $(seq $delay | tac) ;do
		ditto -ne reboot "in $i seconds.."
		sleep 1
	done
	tput cnorm
	echo
	echo
	supervisor reboot
else
	touch $WMREBOOT  # SEE x (script)
	sudo rm -f /tmp/login:console
	# (sleep 0.4; pkill tmux) &
	# (sleep 0.3; console && exec supervisor reboot) &
	# (sleep 0.2; pkill $(cat $HOME/.windowmanager)) &
	# (sleep 0.1; sudo pkill -f "sshd: $USER" 2>/dev/null) &  # close remote ssh session connect
	sudo pkill -f "sshd: $USER" 2>/dev/null  # close remote ssh session connect
	pkill $(cat $HOME/.windowmanager)
fi

