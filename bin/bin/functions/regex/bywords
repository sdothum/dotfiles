# Regex
# ══════════════════════════════════════════════════════════════════════════════

# ..................................................................... by words

# Usage: stdin | bywords [<count>]

n=5  # default number of quoted comma separated words

tr ',' '\n' | sed 's/[ \t]//g; /^$/d' | sort | sed 's/$/,/' | xargs -n ${1:-$n} | sed -r 's/([^ ]*),/"\1",/g'

