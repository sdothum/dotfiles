# ........................................................... modal pipe actions

usage() { echo "<selection> | $(basename $0) l'eader | t'railer | U|u'nderline | r'uler [<char>] | \`code | c'ss | f'old <column> | unF'old
>   where, first word of line is treated as comment symbol
>          '.' -> default leader/trailer 
>          'в”Ѓ' -> default (heavy horizontal) underline
>          'в•ђ' -> default (double horizontal) ruler
>          use '-'  (dash)   for 'в”Ђ' (light horizontal)
>              '--' (dashes) for 'в”Ѓ' (heavy horizontal)
>              '='  (equal)  for 'в•ђ' (double horizontal)" | usage:pipe 
	exit 1
}

# simplified commenting extensions using modal pipe

# env abbreviations
width=${width:-80}
tabwidth=${tabwidth:-3}

[ $2 ] && char="$2"
[ -t 0 ] && usage    # stdin input?
action=${1:-leader}  # default leader .

fill() { for i in $(seq $1) ;do echo -n "$2" ;done }

tab="$(fill $tabwidth " ")"

parse() {
	[ $(printf %c $1) = 'U' ] && return               # simple underline
	[ $(echo -n "$line" | wc -w) -gt 1 ] || return 1  # empty or comment symbol only corner case
	leader=$(echo "$line" | sed -r "s/^([ \t]*).*/\1/")
	spaces=$(echo "$leader" | sed "s/\t/$tab/g")
	comment=$(echo "$line" | sed -r "s/^[ \t]*([^ ]*).*/\1/")
	case $1 in
		r* ) ;;                              # underline page width
		u* ) width=$(echo $line | wc -m) ;;  # underline content
		*  ) # strip existing fill decoration
			[ "$fill" = '.' ] && content=$(echo "$line" | sed -r "s/^[ \t]*[^ ]* (.*)/\1/; s/ *\.\.\.* *//g") \
				|| content=$(echo "$line" | sed -r "s/^[ \t]*[^ ]* (.*)/\1/; s/ *$fill${fill}* *//g") ;;
	esac
	x_spaces=$(echo -n "$spaces" | wc -m)
	x_comment=$(echo -n "$comment" | wc -m)
	[ $x_comment -gt 0 ] || return 1
	x_content=$(echo -n "$content" | wc -m)
	x_decoration=$(( $width - $x_spaces - $x_comment - $x_content - 2 ))
	[ $x_decoration -gt 0 ] && decoration=$(fill $x_decoration "$fill") || return 1
}

# default fillchars
fillchar() {
	case $char in
		-  ) fill='в”Ђ' ;;
		-- ) fill='в”Ѓ' ;;
		=  ) fill='в•ђ' ;;
		*  ) fill=${char:-$1} ;;
	esac
}

code()   { sed 's/\t/  /g; /^[^ ]/s/$/`/; /^ /s/$/\\`/; s/^/`/; s/^`$/` `/'; exit; }  # wiki markdown backtick code block
refold() { [ $1 ] && fold -sw $1 || usage; }
# unfold() { tr '\n' 'вЃ‹' | iconv -f latin1 -t utf-8 | sed -r 's/ *Гў *Гў/вЃ‹/g; s/ Гў/ /g; s/(.)Гў/\1 /g; s/ $//g; s/^Гў/вЃ‹/g; s/вЃ‹/\n\n/g; $a\'''; }  # NOTE: $a\'' adds a blank line
unfold() { tr '\n' 'вЃ‹' | iconv -f latin1 -t utf-8 | sed -r 's/ *Гў *Гў/вЃ‹/g; s/ Гў/ /g; s/(.)Гў/\1 /g; s/ $//g; s/^Гў/вЃ‹/g; s/вЃ‹/\n\n/g'; }           # HACK: utf-8 conversion required for sed (??) tr '\n' 'вЃ‹' -> 'Гў'

case $action in
	\`* ) code       ;;  # wiki codeblock wrapper
	c*  ) sed 's|.*|/* & */|' | align '*/'; exit ;;  # aligned css comments :-)
	f*  ) unfold | refold $2;               exit ;;  # to line wrap column
	*F* ) unfold;                           exit ;;
	l*  ) fillchar . ;;
	t*  ) fillchar . ;;
	U*  ) fillchar в”Ѓ ;;
	u*  ) fillchar в”Ѓ ;;
	r*  ) fillchar в•ђ ;;
	*   ) usage      ;;
esac

while IFS= read -r line ;do
	parse $action || { echo "$line"; continue; }
	case $action in
		l* ) echo "$leader$comment $decoration $content" ;;
		t* ) echo "$leader$comment $content $decoration" ;;
		U* ) echo "$line"; for i in $(seq 1 $width) ;do printf $fill ;done; echo ;;  # special use case for simple underline
		u* ) echo "$line"; echo "$leader$comment $decoration" ;;
		r* ) echo "$line"; echo "$leader$comment $decoration$fill" ;;  # extra fill for lack of parse content
	esac
done

