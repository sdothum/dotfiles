# ................................................................. Create patch

usage() { echo "$(basename $0) @<old> | [<original>] <new>
> where, @<old> is the "old" extension, typically the package manager of the distribution
>        e.g. @xbps for voidlinux
>             @apk for alpine, etc.
>             ${BROWN}SEE:${cyan} original (script)" | usage:
	exit 1
} 

[ "$1" ] || usage

diff2patch() {
	clear
	original=$1
	[ "$2" ] && new=$2 || original=${original}.@$OLD
	diff -u $original ${new:-${original%.@$OLD}} >${new:-${original%.@$OLD}}.patch

	# swacp filenames if ${original}.@$OLD
	[ "$2" ] || sed -i -r '/^--- /s/.@$OLD//; /^\+\+\+ /s/^([^ ]* [^ ]*)\t/\1.update\t/' ${new:-${original%.@$OLD}}.patch
	cat $1.patch | colordiff | cat <(ditto diff2patch "${1%.@$OLD}") - | $PAGER
}

case $1 in
	@* ) OLD=${1#@}; PAGER=less; for i in *.@$OLD ;do diff2patch ${i%.@$OLD} ;done ;;
	*  ) PAGER=${PAGER:-pager}; diff2patch $@ ;;
esac

