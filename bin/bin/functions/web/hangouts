# .............................................................. Google hangouts

BROWSER=luakit
# BROWSER=surf
export NO_PROXY="*"
URL=$(recipe -/ hangouts/url)
CSS="-C $(dirname $0)/.hangouts:stylesheet.css"

case $BROWSER in
	luakit ) luakit -Uu "$URL" 2>/dev/null & ;;  # do not reload previous session NOTE: suppress icp message chatter from google
	surf   ) surf -z1.15 -C $HOME/.config/surf/css/stylesheet.css "$URL" & ;;
	*      ) WIDTH=800 qutebrowser "$URL" & ;;
esac

