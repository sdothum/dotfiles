# .............................................................. Google hangouts

BROWSER=luakit
# BROWSER=surf
export NO_PROXY="*"
URL=$(recipe -/ hangouts/url)
CSS="-C $(dirname $0)/.hangouts:stylesheet.css"

case $BROWSER in
	luakit ) luakit "$URL" & ;;
	surf   ) surf -z1.15 $CSS "$URL" & ;;
	*      ) WIDTH=800 DELAY=1.5 qutebrowser "$URL" & ;;
esac

