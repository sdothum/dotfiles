# ..................................................................... Negative

# Usage: ifno [-c] <message>

sig=${sig:--TERM}

# clear prompt?
[ "$1" = '-c' ] && { clear='printf "\r$(tput el)\n"'; shift; } || clear='echo; echo'

# if no || ..
underline ${YELLOW}$@

while : ;do
	printf "${TEAL}continue? ${RED}[No]${NOCOLOR}/yes/abort : "
	# using bash's extended read functionality (over dash) for single character input
	stty -echo
	stty cbreak
	IFS= read -rn1 CONTINUE
	stty sane
	eval $clear
	case $CONTINUE in
		''   ) exit 0 ;;
		[nN] ) exit 0 ;;
		[yY] ) exit 1 ;;
		[aA] ) { kill $sig ${TMPPID:-$PPID}; break; } ;;  # SEE: tmout
	esac
done

