# ............................................................ digital interface

# Usage: interface [-q] [hdmi | dp | displayport | <interface>]

connected() { xrandr 2>/dev/null | grep "^${1}[^ ]* connected" | cut -d' ' -f1; }

[ "$1" = '-q' ] && { quiet=true; shift; }

INTERFACE=$(echo $1| tr '[:lower:]' '[:upper:]' | sed 's/DISPLAYPORT/DP/')
interface() {
	case $INTERFACE in
		''    ) connected ''         ;;
		HDMI* ) connected $INTERFACE ;;
		DP*   ) connected $INTERFACE ;;
		*     ) connected ${1}       ;;
	esac | head -1  # NOTE: active interface defaults to card port order if <interface>.*
}

interface=$(interface $1)
[ "$interface" ] && { [ $quiet ] || echo $interface; exit 0; } || exit 1

