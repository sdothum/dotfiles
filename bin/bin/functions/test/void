# Usage: void [<init>]

void() { [ -e /usr/bin/xbps-install ]; }

case $1 in
	''    ) void ;;
	dinit ) grep -q 'dinit' /sbin/init ;;  # updated to accommodate chimera-dinit install
	*     ) void && ls -l /sbin/init | grep -q "$1" ;;
esac

