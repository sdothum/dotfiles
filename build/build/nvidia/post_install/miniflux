# Make_install
# ══════════════════════════════════════════════════════════════════════════════

# ..................................................................... miniflux

if void 'dinit' ;then
	. /etc/dinit.d/config/postgres.env
	POSTGRESQL=postgres
	sv stop postgres
	sv stop postgres-pre
else
	VERSION=18
	POSTGRESQL=postgresql$VERSION
fi
export PGDATA=/var/lib/postgresql${VERSION}/data

# HTTP=nginx
HTTP=caddy
FONT=ottawa  # my ebook font :)

sv enable $POSTGRESQL
sv start $POSTGRESQL

# HACK: add superuser to miniflux user to overcome miniflux.app pq error
echo "
create user miniflux with superuser password 'miniflux';
-- alter user miniflux set work_mem='64MB';
create database miniflux;
grant all privileges on database miniflux to miniflux;
\connect miniflux;
create extension hstore;
" >/tmp/miniflux:postgres.sql


if ! grep -q PGDATA $HOME/.profile ;then
	sed -i "/export PGDATA=/s|=.*|=$PGDATA|" $HOME/.profile
	grep -q 'export PGDATA=' $HOME/.profile || sed -i "1iexport PGDATA=$PGDATA" $HOME/.profile
fi
sudo mkdir -p $PGDATA
sudo chown -R postgres:postgres ${PGDATA%/data}

# NOTE: postgres socket is erroneously not found from shell script (??) cause unknown
ditto postgres "execute the following in a new terminal before continuing.."
ditto postgres "sudo -u postgres psql --echo-all -f /tmp/miniflux:postgres.sql"
ifno "complete miniflux install.." && exit

# sudo sed -i '/^local *all *all *trust/s/trust/md5/' /var/lib/$POSTGRESQL/data/pg_hba.conf
sv restart $POSTGRESQL
sleep 5  # wait for database to come back up

# high polling low batch for reddit throttle
# HACK: user/password changed from postgres/secret (on miniflux documentation)
echo "
BASE_URL=http://10.1.0.11
BATCH_SIZE=6
CLEANUP_ARCHIVE_READ_DAYS=4
CLEANUP_ARCHIVE_UNREAD_DAYS=4
CLEANUP_FREQUENCY_HOURS=1
CLEANUP_REMOVE_SESSIONS_DAYS=9999
DATABASE_URL=user=miniflux password=miniflux dbname=miniflux sslmode=disable
INTEGRATION_ALLOW_PRIVATE_NETWORKS=1
LISTEN_ADDR=127.0.0.1:8080
LOG_DATE_TIME=yes
POLLING_FREQUENCY=1
POLLING_PARSING_ERROR_LIMIT=0
POLLING_SCHEDULER=round_robin
USER_AGENT=Miniflux/RedditFeed (by /u/sdothum) Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36 MyMinifluxBot/1.0
WORKER_POOL_SIZE=5
" | sudo tee /etc/miniflux.conf

void dinit || sudo grep -q miniflux.conf /etc/sv/miniflux/run || sudo sed -i '/exec .* miniflux.app/s|$| -c /etc/miniflux.conf|' /etc/sv/miniflux/run  # HACK: see above

miniflux.app -c /etc/miniflux.conf -migrate
miniflux.app -c /etc/miniflux.conf -create-admin

sudo rm -f /etc/$HTTP/http.d/miniflux.*
# stow $HTTP/miniflux
sv restart $HTTP
sv enable miniflux
sv start miniflux

sudo mkdir -pv /var/www/localhost/fonts
sudo cp -v $HOME/.local/share/fonts/$FONT/*.ttf /var/www/miniflux/fonts
ditto miniflux "create new miniflux api key"
ditto dinit "update reddit-miniflux script with new miniflux api key"

# kak: filetype=sh
