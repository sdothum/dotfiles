# use faster repos
! sed 's/default/fastly/' /usr/share/xbps.d/00-repository-main.conf | sudo tee /etc/xbps.d/00-repository-main.conf
! sed 's/default/fastly/' /usr/share/xbps.d/10-repository-nonfree.conf | sudo tee /etc/xbps.d/10-repository-nonfree.conf
! sudo xbps-install -Su


# first things first
= autologin
= ═════════
! sudo sed -i "/GETTY_ARGS/s/--noclear/--autologin ${USER}/" /etc/sv/agetty-tty1/conf
" grab usrid 1001 for rw permission to nfs/sonarr
! sudo useradd sonarr
! sudo usermod -aG sonarr shum
! sudo usermod -aG input shum


= hostname
= ════════
  inetutils-hostname
! cfg_install /etc/hosts motu


= console font
= ════════════
  terminus-font
! setfont ter-i18b
! sudo sed -i '/#FONT=/aFONT=teri18b' /etc/rc.conf


= linux firmware
= ══════════════
  linux-firmware
  linux-firmware-network
  wifi-firmware


# NOTE: dracut replaced with booster for minimal boot images SEE: nvidia for subsequent image rebuild

= initramfs
= ═════════
  booster
! sudo xbps-alternatives -s booster
! echo "modules: kernel/drivers/video/nvidia.ko,kernel/drivers/video/nvidia-modeset.ko,kernel/drivers/video/nvidia-uvm.ko,kernel/drivers/video/nvidia-drm.ko
strip: true
" | sudo tee -a /etc/booster.yaml


= nvidia
= ══════
# void-repo-multilib-nonfree
# vulkan-loader
  void-repo-nonfree
! sudo xbps-install -Su
  nvidia
# ! sudo xbps-reconfigure -f linux$(uname -r | cut -d. -f-2)
! sudo xbps-reconfigure -f linux
# NOTE: only display init error messages (0-3)
! sudo sed -i \'/GRUB_CMDLINE_LINUX_DEFAULT/s/=.*/=\"loglevel=3 nvidia-drm.modeset=1\"/; s/.*GRUB_GFXMODE=.*/GRUB_GFXMODE=3440x1440x32/\' /etc/default/grub
! cat /etc/default/grub
! ifno "grub ok" && exit 1
! sudo update-grub


