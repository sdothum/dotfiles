#!/usr/bin/dash
# sdothum - 2016 (c) wtfpl
[ $TRACE ] && CHILD="cbonsai $@" . $PARENT

# Faouzia
# ══════════════════════════════════════════════════════════════════════════════

# ............................................................... Ncurses bonsai

# Usage: cbonsai [single]

[ $1 ] || repeat=-iw15

CBONSAI="$HOME/.local/bin/cbonsai -l -t0.125 $repeat"

nimctlr window toggle cbonsai || term cbonsai BLACKBOARD $CBONSAI

# kak: filetype=sh
