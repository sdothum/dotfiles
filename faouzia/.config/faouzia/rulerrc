# ........................................................................ audio

class="audacious"
	nimctlr window group $(nimctlr group id "PLAY") . window snap center

# delay for pavucontrol/pipewire sync SEE: pulse

class="pavucontrol"
	NIMCTLR_TRACE=1 nimctlr rule pavucontrol

# ........................................................................ media

class="asunder"
	nimctlr window group $(nimctlr group id "UTIL")                                                            ;\
	[ -e /tmp/rulerrc:asunder ] && sirocco window_stack_toggle || nimctlr window size 1/3 . window snap center ;\
	touch /tmp/rulerrc:asunder

class="calibre"
	NIMCTLR_TRACE=1 nimctlr rule calibre

class="nicotine"
	NIMCTLR_TRACE=1 nimctlr rule nicotine

