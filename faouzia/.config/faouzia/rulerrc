# ......................................................................... mail

class="aerc"
	NIMCTLR_TRACE=1 nimctlr rule aerc ;\
	xdotool type ':vsplit' && xdotool key Return

# open compose window but raise aerc to complete to/subject fields

class="email"
	nimctlr window tile 3 2 . window group $(nimctlr group id "COMM") ;\
	sirocco window_stack_toggle

class="compose"
	nimctlr window tile 3 2 . window group $(nimctlr group id "COMM")

