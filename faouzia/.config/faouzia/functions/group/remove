[ $TRACE ] && CHILD="group/remove $@" . $PARENT

# Faouzia
# ══════════════════════════════════════════════════════════════════════════════

# ......................................................... Group remove (winid)

# Usage: group remove [<winid>]

winid=${1:-$(pfw)}

for i in $(find $GROUP -name $winid) ;do
	rmdir $i
done

for i in $(find $GROUP:deactivated -name $winid) ;do
	rmdir $i
done

