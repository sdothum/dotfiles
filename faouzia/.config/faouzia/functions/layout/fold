# .................................................................. Tile layout

usage() { usage: "$(basename $0) fold [--] 0 | 1 | 2 | 3 | 4 | 5 [x2] [<classname>]"; exit 1; }

winids=$(sirocco window ids ${3:-$2})
instance=0  # window placement sequence
tile=tile
[ "$1" = '--' ] && { tile=spread; shift; }

# ........................................................................ Stack

stack() {
	for i in $winids ;do
		sirocco window focus $i
		$NIMCTLR window size monocle
	done
}

stack_matrix() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			0 ) $NIMCTLR window $tile 1x2 1 top    ;;
			1 ) $NIMCTLR window $tile 1x2 1 bottom ; instance=-1  ;;
		esac
		instance=$(( instance + 1 ))
	done
}

# .................................................................... By halves

halves() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			0 ) $NIMCTLR window tile 2 1 ;;
			1 ) $NIMCTLR window tile 2 2 ; instance=-1 ;;
		esac
		instance=$(( instance + 1 ))
	done
}

halves_matrix() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			0 ) $NIMCTLR window $tile 2x2 1 top    ;;
			1 ) $NIMCTLR window $tile 2x2 1 bottom ;;
			2 ) $NIMCTLR window $tile 2x2 2 top    ;;
			3 ) $NIMCTLR window $tile 2x2 2 bottom ; instance=-1 ;;
		esac
		instance=$(( instance + 1 ))
	done
}

# .................................................................... By thirds

thirds() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			2 ) $NIMCTLR window tile 3 1 ; instance=-1 ;;
			0 ) $NIMCTLR window tile 3 2 ;;
			1 ) $NIMCTLR window tile 3 3 ;;
		esac
		instance=$(( instance + 1 ))
	done
}

thirds_matrix() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			4 ) $NIMCTLR window $tile 3x2 1 top    ;;
			5 ) $NIMCTLR window $tile 3x2 1 bottom ; instance=-1 ;;
			0 ) $NIMCTLR window $tile 3x2 2 top    ;;
			1 ) $NIMCTLR window $tile 3x2 2 bottom ;;
			2 ) $NIMCTLR window $tile 3x2 3 top    ;;
			3 ) $NIMCTLR window $tile 3x2 3 bottom ;;
		esac
		instance=$(( instance + 1 ))
	done
}

# .................................................................. By quarters

quarters() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			3 ) $NIMCTLR window tile 4 1 ; instance=-1 ;;
			2 ) $NIMCTLR window tile 4 2 ;;
			0 ) $NIMCTLR window tile 4 3 ;;
			1 ) $NIMCTLR window tile 4 4 ;;
		esac
		instance=$(( instance + 1 ))
	done
}

quarters_matrix() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			6 ) $NIMCTLR window $tile 4x2 1 top    ;;
			7 ) $NIMCTLR window $tile 4x2 1 bottom ; instance=-1 ;;
			4 ) $NIMCTLR window $tile 4x2 2 top    ;;
			5 ) $NIMCTLR window $tile 4x2 2 bottom ;;
			0 ) $NIMCTLR window $tile 4x2 3 top    ;;
			1 ) $NIMCTLR window $tile 4x2 3 bottom ;;
			2 ) $NIMCTLR window $tile 4x2 4 top    ;;
			3 ) $NIMCTLR window $tile 4x2 4 bottom ;;
		esac
		instance=$(( instance + 1 ))
	done
}

# .................................................................... By fifths

fifths() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			4 ) $NIMCTLR window tile 5 1 ; instance=-1 ;;
			3 ) $NIMCTLR window tile 5 2 ;;
			0 ) $NIMCTLR window tile 5 3 ;;
			1 ) $NIMCTLR window tile 5 4 ;;
			2 ) $NIMCTLR window tile 5 5 ;;
		esac
		instance=$(( instance + 1 ))
	done
}

fifths_matrix() {
	for i in $winids ;do
		sirocco window focus $i
		case $instance in
			8 ) $NIMCTLR window $tile 5x2 1 top    ;;
			9 ) $NIMCTLR window $tile 5x2 1 bottom ; instance=-1 ;;
			6 ) $NIMCTLR window $tile 5x2 2 top    ;;
			7 ) $NIMCTLR window $tile 5x2 2 bottom ;;
			0 ) $NIMCTLR window $tile 5x2 3 top    ;;
			1 ) $NIMCTLR window $tile 5x2 3 bottom ;;
			2 ) $NIMCTLR window $tile 5x2 4 top    ;;
			3 ) $NIMCTLR window $tile 5x2 4 bottom ;;
			4 ) $NIMCTLR window $tile 5x2 5 top    ;;
			5 ) $NIMCTLR window $tile 5x2 5 bottom ;;
		esac
		instance=$(( instance + 1 ))
	done
}

# ........................................................... Fold across screen

case "$1" in
	*x2 )
		case "${1%x2}" in
			0 ) $NIMCTLR layout fold $(min $(echo "$winids" | wc -l) 5)x2 $2 ;;
			1 ) stack_matrix    ;;
			2 ) halves_matrix   ;;
			3 ) thirds_matrix   ;;
			4 ) quarters_matrix ;;
			5 ) fifths_matrix   ;;
			* ) usage ;;
		esac
		;;
	*   )
		case "$1" in
			0 ) $NIMCTLR layout fold $(min $(echo "$winids" | wc -l) 5) $2 ;;
			1 ) stack    ;;  # monocle
			2 ) halves   ;;
			3 ) thirds   ;;
			4 ) quarters ;;
			5 ) fifths   ;;
			* ) usage ;;
		esac
esac

sirocco window focus $winid

