[ $TRACE ] && CHILD="layout/spread $@" . $PARENT

# Windowchef
# ══════════════════════════════════════════════════════════════════════════════

# ............................................................... Spread windows

# Usage: layout spread <columns>[x2] <name>

linear() {
	pos=$(expr $pos % $1)   # position left to right
	[ $pos -eq 0 ] && pos=$1
	case $1 in
		2 ) echo 2 1 ;;
		3 ) echo 2 3 1 ;;
		4 ) echo 2 3 1 4 ;;
		5 ) echo 3 2 4 1 5 ;;
		* ) echo $1 ;;
	esac | cut -d' ' -f$pos
}

matrix() {
	[ $(expr $pos % 2) -eq 1 ] && row=top || row=bottom  # position top to bottom..
	pos=$(( (pos + 1) / 2 ))
	echo $(linear $1) $row                               # left to right
}

case $1 in
	*x2 )
		pos=$(chef window count $2)
		window @$(pfw) spread $1 $(matrix ${1%x2})
		;;
	*   )
		pos=$(chef window count $2)
		window @$(pfw) spread $1 $(linear $1)
		;;
esac

