#!/usr/bin/dash
# sdothum - 2016 (c) wtfpl
[ $TRACE ] && CHILD="bin/gaps $@" . $PARENT

# herbstluftwm
# ══════════════════════════════════════════════════════════════════════════════

# ................................................................. Tweak layout

# NOTE: panel is lost on exit, cause unknown (windowchefrc?) SEE: abbreviations.fish for usage fix (respawn)

usage() {
	echo "$(basename $0) (interative mode.. <Return> to exit)
> ${GREEN}toggle:${cyan} -'borders
> ${GREEN}tuples:${cyan} w'idth | internal W'idth <border>
>         f'ocused | internal F'ocused | u'nfocused | internal U'nfocused <color>
>         t'op | b'ottom | l'eft | r'ight | g'rid <gap>
>         h'eight | i'ndent <panel>
>         where, border/gap/height/indent: <pixel>  count
>                color:                    <rrggbb> hex${NOCOLOR}" | usage:
}

# SEE: windowchefrc
snapshot() {
	enable_borders=$(recipe ui/enable_borders)
	border_width=$(recipe ui/border_width)
	internal_border_width=$(recipe ui/internal_border_width)
	color_focused=$(recipe ui/color_focused)
	color_unfocused=$(recipe ui/color_unfocused)
	internal_color_focused=$(recipe ui/internal_color_focused)
	internal_color_unfocused=$(recipe ui/internal_color_unfocused)
	gap_width_top=$(recipe 'ui/gap_width top')
	gap_width_bottom=$(recipe 'ui/gap_width bottom')
	gap_width_left=$(recipe 'ui/gap_width left')
	gap_width_right=$(recipe 'ui/gap_width right')
	grid_gap_width=$(recipe ui/grid_gap_width)
	panel_height=$(recipe panel/height)
	panel_indent=$(recipe panel/indent)
}

recover() {
	recipe ui/enable_borders $enable_borders
	recipe ui/border_width $border_width
	recipe ui/internal_border_width $internal_border_width
	recipe ui/color_focused $color_focused
	recipe ui/color_unfocused $color_unfocused
	recipe ui/internal_color_focused $internal_color_focused
	recipe ui/internal_color_unfocused $internal_color_unfocused
	recipe 'ui/gap_width top' $gap_width_top
	recipe 'ui/gap_width bottom' $gap_width_bottom
	recipe 'ui/gap_width left' $gap_width_left
	recipe 'ui/gap_width right' $gap_width_right
	recipe ui/grid_gap_width $grid_gap_width
	recipe panel/height $panel_height
	recipe panel/indent $panel_indent

	config
}

settings() {
	echo "
	${ORANGE}-${NOCOLOR}enable borders          "$(recipe ui/enable_borders)"
	border ${ORANGE}w${NOCOLOR}idth             "$(recipe ui/border_width)"
	internal border ${ORANGE}W${NOCOLOR}idth    "$(recipe ui/internal_border_width)"
	color ${ORANGE}f${NOCOLOR}ocused            "$(recipe ui/color_focused)"
	color ${ORANGE}u${NOCOLOR}nfocused          "$(recipe ui/color_unfocused)"
	internal color ${ORANGE}F${NOCOLOR}ocused   "$(recipe ui/internal_color_focused)"
	internal color ${ORANGE}U${NOCOLOR}nfocused "$(recipe ui/internal_color_unfocused)"
	gap width ${ORANGE}t${NOCOLOR}op            "$(recipe 'ui/gap_width top')"
	gap width ${ORANGE}b${NOCOLOR}ottom         "$(recipe 'ui/gap_width bottom')"
	gap width ${ORANGE}l${NOCOLOR}eft           "$(recipe 'ui/gap_width left')"
	gap width ${ORANGE}r${NOCOLOR}ight          "$(recipe 'ui/gap_width right')"
	${ORANGE}g${NOCOLOR}rid gap width           "$(recipe ui/grid_gap_width)"
	panel ${ORANGE}h${NOCOLOR}eight             "$(recipe panel/height)"
	panel ${ORANGE}i${NOCOLOR}ndent             "$(recipe panel/indent)"
"
}

usage
snapshot

# semi-dynamic rice tweaking
config() {
	windowchefrc refresh
	[ $panel ] && { pkill -f 'draw panel'; restore panel; }
	return 0
}

color() { pastel format hex $value >/dev/null 2>&1; }

while : ;do
	settings
	unset panel

	read -p '> ' config
	[ "$config" ] || break
	attr=${config%% *}
	value=${config##* }

	case $attr in
		- ) [ $(recipe ui/enable_borders) = 'true' ] && value=false || value=true ;;
		f ) color $value || { usage; continue; } ;;
		F ) color $value || { usage; continue; } ;;
		u ) color $value || { usage; continue; } ;;
		U ) color $value || { usage; continue; } ;;
		* ) echo $value | grep -q '[^0-9]' && { usage; continue; } ;;
	esac

	case $attr in
		- ) recipe ui/enable_borders $value ;;
		w ) recipe ui/border_width $value ;;
		W ) recipe ui/internal_border_width $value ;;
		f ) recipe ui/color_focused $value ;;
		F ) recipe ui/color_unfocused $value ;;
		u ) recipe ui/internal_color_focused $value ;;
		U ) recipe ui/internal_color_unfocused $value ;;
		t ) recipe 'ui/gap_width top' $value; recipe 'ui/gap_width bottom' $value ;;  # NOTE: sets balanced margins by default
		b ) recipe 'ui/gap_width bottom' $value ;;
		l ) recipe 'ui/gap_width left' $value; recipe 'ui/gap_width right' $value ;;
		r ) recipe 'ui/gap_width right' $value ;;
		g ) recipe ui/grid_gap_width $value ;;
		h ) recipe panel/height $value; panel=true ;;
		i ) recipe panel/indent $value; panel=true ;;
		* ) usage; continue ;;
	esac

	config
done

ifno 'save .session' && recover || ditto gaps "saved :-)"

# kak: filetype=sh
