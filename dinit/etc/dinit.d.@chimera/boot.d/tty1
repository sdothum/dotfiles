
type            = process
# command       = /sbin/agetty --noclear tty2 38400 linux
command         = /sbin/agetty --noclear tty1 38400 linux --autologin shum
restart         = true
depends-on      = login.target
waits-for       = early-dev-trigger
termsignal      = HUP
smooth-recovery = true
inittab-id      = 1
inittab-line    = tty1
