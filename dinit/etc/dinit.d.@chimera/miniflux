type            = process
# command       = /etc/dinit.d/scripts/miniflux
command         = /usr/bin/miniflux.app -c /etc/miniflux.conf
env-file        = /etc/dinit.d/config/miniflux.env
run-as          = _miniflux
smooth-recovery = yes
logfile         = /var/log/dinit.d/miniflux.log
depends-on      = caddy
depends-on      = postgres
